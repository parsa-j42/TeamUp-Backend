NODE_ENV=development
PORT=3000

# Postgres — use individual params (Neon: set DB_SSL=true)
DB_HOST=
DB_PORT=5432
DB_USERNAME=
DB_PASSWORD=
DB_DATABASE=
DB_SSL=false

# AWS Cognito
AWS_REGION=
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

# Recommendations LLM
# Provider: groq (default) or gemini. Switchable without code changes.
LLM_PROVIDER=groq
# Optional comma-separated model override, tried in order (fallback chain).
# Defaults: groq=llama-3.3-70b-versatile,qwen/qwen3-32b,openai/gpt-oss-20b
#           gemini=gemini-2.5-flash
LLM_MODEL=
# Set the key matching LLM_PROVIDER
GROQ_API_KEY=
GEMINI_API_KEY=

# CORS — space or comma separated origins (e.g. https://teamup.parsaj.dev)
# Defaults to http://localhost:5173 if not set
CORS_ORIGIN=http://localhost:5173

# Demo account email — used by the seed script to identify the shared demo user
DEMO_USER_EMAIL=
